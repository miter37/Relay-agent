# ─── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Packaging / build output
build/
dist/
*.egg-info/
.eggs/

# Relay build artifacts — published only as GitHub Release assets.
# Generated by `python build_release.py`; never committed.
relay.pyz
SHA256SUMS.txt
MANIFEST.txt

# ─── Tests / coverage ─────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/

# ─── Runtime data ─────────────────────────────────────
# Relay stores these under the per-user home directory
# (%LOCALAPPDATA%\Relay, ~/Library/Application Support/Relay, ~/.relay),
# not inside the repository. Listed here only as a safety net in case
# RELAY_HOME is pointed at a working copy during development.
relay.db
*.sqlite
*.sqlite3
workspaces/
staging/

# ─── Editors / OS ─────────────────────────────────────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini
