#!/bin/sh
case " $* " in
  *" --version "*|*" -V "*|" version ") echo "claude mock 9.9.9"; exit 0 ;;
  *" --help "*|*" -h "*) echo "-p --output-format --permission-mode --json-schema --max-turns --tools --no-session-persistence"; exit 0 ;;
esac
export RELAY_PROVIDER_NAME=claude
exec python3 "$(dirname "$0")/mock_ai_cli.py" "$@"
